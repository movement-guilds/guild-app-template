# Discord OAuth — create a separate app per guild app in Developer Portal
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=1101576619493167217
NEXTAUTH_SECRET=

# NextAuth — Set to http://localhost:3000 for local dev. Leave blank for Vercel (auto-detected)
NEXTAUTH_URL=http://localhost:3000

# Role IDs — set per app from the Movement Discord server
DISCORD_ADMIN_ROLE_ID=
DISCORD_MOD_ROLE_ID=
# Add app-specific role IDs here (e.g. DISCORD_CREATOR_ROLE_ID= for a submission app)

# Supabase — shared project, per-app Postgres schema
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # Vercel env vars only — never in GitHub secrets

# Supabase CLI only — used for: supabase link --project-ref $SUPABASE_PROJECT_REF
# NOT a runtime variable — do not set in Vercel env vars
SUPABASE_PROJECT_REF=

# Movement Network
MOVEMENT_RPC_MAINNET=https://mainnet.movementnetwork.xyz/v1
MOVEMENT_RPC_TESTNET=https://testnet.movementnetwork.xyz/v1

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Error tracking
SENTRY_DSN=

# Wallet <> Discord identity linking
# Set to true to require wallet link after Discord login; false = table exists but not enforced
REQUIRE_WALLET_LINK=false
